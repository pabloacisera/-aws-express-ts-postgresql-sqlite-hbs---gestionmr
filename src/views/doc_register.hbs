<script>
// Al final de tu archivo doc_register.js o dentro del DOMContentLoaded
const btnUpdateLicencia = document.getElementById('btn-update-licencia');
const inputLicencia = document.getElementById('licencia_vencimiento_input');
const feedbackLicencia = document.getElementById('licencia-feedback');

btnUpdateLicencia.addEventListener('click', async () => {
    const nuevaFecha = inputLicencia.value;
    const controlId = document.getElementById('control-id').value;

    if (!nuevaFecha) {
        alert('Por favor, selecciona una fecha válida');
        return;
    }

    try {
        btnUpdateLicencia.disabled = true;
        btnUpdateLicencia.innerHTML = '<span class="spinner-border spinner-border-sm"></span> Actualizando...';

        const response = await fetch(`/api/registers-control/${controlId}/update-licencia`, {
            method: 'PATCH',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ licencia_vencimiento: nuevaFecha })
        });

        const result = await response.json();

        if (result.success) {
            feedbackLicencia.className = 'alert alert-success mt-2 p-2 small';
            feedbackLicencia.innerHTML = '✅ Fecha de licencia actualizada correctamente';
            feedbackLicencia.style.display = 'block';
        } else {
            throw new Error(result.error || 'Error desconocido');
        }
    } catch (error) {
        feedbackLicencia.className = 'alert alert-danger mt-2 p-2 small';
        feedbackLicencia.innerHTML = '❌ Error: ' + error.message;
        feedbackLicencia.style.display = 'block';
    } finally {
        btnUpdateLicencia.disabled = false;
        btnUpdateLicencia.innerHTML = '<i class="fas fa-save me-2"></i> Actualizar Fecha Licencia';
    }
});
</script>

<script type="module" src="/js/doc_register.js"></script>